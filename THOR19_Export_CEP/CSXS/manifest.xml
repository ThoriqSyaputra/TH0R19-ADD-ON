<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<ExtensionManifest Version="7.0" ExtensionBundleId="com.thor19.export" ExtensionBundleVersion="1.0.0" ExtensionBundleName="THOR19 Export">

  <ExtensionList>
    <Extension Id="com.thor19.export.panel" Version="1.0.0"/>
  </ExtensionList>

  <ExecutionEnvironment>
    <HostList>
      <!-- Adobe Illustrator CC 2019 (23) hingga 2025 (29) -->
      <Host Name="ILST" Version="[23.0,99.9]"/>
    </HostList>

    <LocaleList>
      <Locale Code="All"/>
    </LocaleList>

    <RequiredRuntimeList>
      <RequiredRuntime Name="CSXS" Version="7.0"/>
    </RequiredRuntimeList>
  </ExecutionEnvironment>

  <DispatchInfoList>
    <Extension Id="com.thor19.export.panel">
      <DispatchInfo>

        <Resources>
          <!-- Entry point HTML panel -->
          <MainPath>./index.html</MainPath>
          <!-- ExtendScript entry point -->
          <ScriptPath>./host/bridge.jsx</ScriptPath>
          <!-- CEP debugging port (Chrome DevTools) -->
          <CEFCommandLine>
            <Parameter>--allow-file-access-from-files</Parameter>
            <Parameter>--allow-running-insecure-content</Parameter>
          </CEFCommandLine>
        </Resources>

        <Lifecycle>
          <AutoVisible>true</AutoVisible>
        </Lifecycle>

        <UI>
          <Type>Panel</Type>
          <Menu>THOR19 Export</Menu>
          <Geometry>
            <Size>
              <Height>520</Height>
              <Width>320</Width>
            </Size>
            <MinSize>
              <Height>400</Height>
              <Width>280</Width>
            </MinSize>
            <MaxSize>
              <Height>900</Height>
              <Width>600</Width>
            </MaxSize>
          </Geometry>
          <Icons>
          </Icons>
        </UI>

      </DispatchInfo>
    </Extension>
  </DispatchInfoList>

</ExtensionManifest>
